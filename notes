#判断：
#1. .startswith（）：是否某个子字符串开头，是则返回Ture，不是的话返回Flase， 同上也可设定范围
#st = 'liweijia'
#print(st.startswith('l'))    #返回为Ture
#print(st.startswith('l',1,6))   #返回为Flase



#2. .endswith(): 是否以某个子字符串结尾，是则返回Ture，不是的话返回Flase， 同上也可设定范围
#name = 'Liweijia'
#print(name.endswith('a'))  #Ture


